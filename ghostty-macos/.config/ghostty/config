# File: ~/.config/ghostty/config

font-family = "JetBrainsMono Nerd Font"
font-size = 14
font-thicken = true
adjust-cell-height = 2

theme = Atom One Dark

background-opacity = 0.85
background-blur-radius = 30
macos-titlebar-style = transparent
window-padding-x = 10
window-padding-y = 8
window-save-state = never
window-theme = auto
unfocused-split-opacity = 0.8

cursor-style = bar
cursor-style-blink = true
cursor-opacity = 0.8

mouse-hide-while-typing = true
copy-on-select = clipboard

quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.15

clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true
shell-integration = detect
macos-option-as-alt = true

keybind = cmd+t=unbind
keybind = cmd+shift+left=unbind
keybind = cmd+shift+right=unbind
keybind = cmd+d=unbind
keybind = cmd+shift+d=unbind
keybind = cmd+alt+left=unbind
keybind = cmd+alt+right=unbind
keybind = cmd+alt+up=unbind
keybind = cmd+alt+down=unbind
keybind = cmd+shift+e=unbind
keybind = cmd+shift+f=unbind
keybind = ctrl+a=unbind
keybind = resize/up=unbind
keybind = resize/down=unbind
keybind = resize/left=unbind
keybind = resize/right=unbind
keybind = resize/escape=unbind
keybind = resize/catch_all=unbind
keybind = global:ctrl+grave_accent=unbind

keybind = cmd+plus=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+zero=reset_font_size
keybind = global:ctrl+grave_accent=toggle_quick_terminal
keybind = cmd+shift+e=equalize_splits
keybind = cmd+shift+f=toggle_split_zoom
keybind = cmd+shift+comma=reload_config
# Run the zellij session picker from a shell prompt.
keybind = cmd+shift+j=text:"\x15fzj\n"

scrollback-limit = 25000000
# Use the macOS system alert sound for BEL. Codex uses BEL for approvals and task-complete alerts.
bell-features = system
