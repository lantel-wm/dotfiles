#!/usr/bin/env zsh

emulate -L zsh
setopt pipefail no_aliases

(( $+commands[zellij] )) || { print -u2 -- "zellij not found in PATH"; exit 127; }
(( $+commands[fzf] )) || { print -u2 -- "fzf not found in PATH"; exit 127; }

local sessions selected rc

sessions="$(zellij list-sessions --short --no-formatting 2>/dev/null)"
rc=$?
(( rc == 0 )) || { print -u2 -- "failed to list zellij sessions"; exit $rc; }
[[ -n $sessions ]] || { print -u2 -- "no active zellij sessions"; exit 1; }

selected="$(
  print -r -- "$sessions" |
    fzf \
      --prompt='zellij session > ' \
      --layout='reverse' \
      --cycle \
      --border \
      --header='Enter switch, Esc cancel, Ctrl-/ preview' \
      --preview-window='right,55%,border-left,hidden' \
      --bind='ctrl-/:toggle-preview' \
      --preview '
        session={}
        zellij list-sessions 2>/dev/null |
          awk -v name="$session" '"'"'index($0, name) { print; exit }'"'"'
        clients="$(
          zellij --session "$session" action list-clients 2>/dev/null |
            awk "NR > 1 && NF { count++ } END { print count + 0 }"
        )"
        printf "\033[1;33mClients:\033[0m %s\n" "$clients"
      '
)"
rc=$?
(( rc == 0 )) && [[ -n $selected ]] || exit $rc

if [[ -n ${ZELLIJ:-} ]]; then
  zellij action switch-session -- "$selected"
else
  exec zellij attach -- "$selected"
fi
